#include <iostream>
#include <unordered_set>
using namespace std;

int longestConsecutive(int arr[], int n)
{
    unordered_set<int> s;

    for(int i = 0; i < n; i++)
    {
        s.insert(arr[i]);
    }

    int longest = 0;

    for(int i = 0; i < n; i++)
    {
        if(s.find(arr[i] - 1) == s.end())
        {
            int current = arr[i];
            int count = 1;

            while(s.find(current + 1) != s.end())
            {
                current++;
                count++;
            }

            if(count > longest)
            {
                longest = count;
            }
        }
    }

    return longest;
}